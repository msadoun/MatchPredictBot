TELEGRAM_BOT_TOKEN=your_bot_token_from_botfather
ADMIN_USER_IDS=123456789,987654321
DATABASE_PATH=data/bot.db
# REQUIRED on Railway: mount a persistent volume at /app/data
# (stores bot.db, predictions_archive.jsonl, backups/, exports/*.xlsx)
# Without this volume, every code deploy WIPES all predictions!
#
# Optional: remote backup URL (GET returns JSON, POST accepts JSON) — survives redeploys
# REMOTE_PREDICTION_BACKUP_URL=https://your-backup-endpoint.example/predictions
# REMOTE_PREDICTION_BACKUP_TOKEN=optional_bearer_token
# Optional: chat ID for https://t.me/alkoram3na (if @username lookup fails)
# ALKORAM3NA_GROUP_CHAT_ID=-1001260044677
# K m3na groub — defaults to -1001298782951 (Telegram ID 1001298782951)
# KM3NA_GROUP_CHAT_ID=-1001298782951
# Auto base points for @M2usab in any group (added to prediction points)
# M2USAB_TELEGRAM_ID=10140530
# M2USAB_AUTO_GROUP_POINTS=24
# Optional: fill ONLY missing predictions (never overwrites existing picks)
# PREDICTION_BACKFILLS=M2usab:35:3-0
