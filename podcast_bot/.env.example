# Telegram bot token from @BotFather (use a dedicated bot, not MatchPredictBot)
PODCAST_BOT_TOKEN=your_bot_token_here

# Public URL where this service is reachable (required for podcast apps)
# Local dev with ngrok: https://abc123.ngrok-free.app
# Railway: https://your-service.up.railway.app
BASE_URL=http://localhost:8080

# HTTP port for RSS feeds and audio redirects
PORT=8080

# SQLite database path
PODCAST_DATABASE_PATH=data/podcast_bot.db

# Max episodes per feed (playlists/channels)
MAX_EPISODES=50
